# Environment Variables Example
# Copy this file to .env.local and fill in your actual values

# Sanity CMS Configuration
# Get these from: https://manage.sanity.io → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
# Use a token with Editor (write) access for imports / scripts; Viewer is read-only.
SANITY_API_TOKEN=your_api_token_here
# Optional: how often (seconds) to refetch Sanity in Next.js Data Cache (default 60)
# SANITY_FETCH_REVALIDATE_SECONDS=60

# Optional: Supporting Page Generator (Sanity Studio tool → Next.js API)
# GENERATOR_ADMIN_SECRET=your_long_random_secret
# Live links in Studio results (defaults to https://www.melatoningummiesuk.com on localhost/Vercel preview)
# GENERATOR_PUBLIC_SITE_URL=https://www.melatoningummiesuk.com
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_API_KEY=optional_fallback
# Optional: Sanity webhook → POST /api/revalidate
# SANITY_REVALIDATE_SECRET=your_long_random_secret

# Resend Email Configuration
# Get this from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# Verified sender, e.g. "MelatoninGummiesUK <noreply@melatoningummiesuk.com>" — dev fallback: onboarding@resend.dev
RESEND_FROM_EMAIL=
# Inbox for wholesale inquiry notifications (defaults to wholesale@melatoningummiesuk.com)
WHOLESALE_NOTIFY_EMAIL=
# Optional separate inbox for /contact form (defaults to WHOLESALE_NOTIFY_EMAIL, then wholesale@melatoningummiesuk.com)
CONTACT_NOTIFY_EMAIL=

# Google Analytics Configuration
# Get this from: https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G_your_measurement_id_here

# Site Configuration
# The full domain/URL of your site
NEXT_PUBLIC_SITE_URL=https://localhost:3000

# WhatsApp floating widget (digits only, include country code — default: 447418373634)
# NEXT_PUBLIC_WHATSAPP_NUMBER=447418373634
# When unset/false, /contact shows "[Email]" in the sidebar and hides mailto. Set to true when the public inbox is final.
# NEXT_PUBLIC_SHOW_CONTACT_EMAIL=true

# Optional: Vercel Environment (auto-set on Vercel)
# VERCEL_ENV=production
# VERCEL_URL=localhost:3000
